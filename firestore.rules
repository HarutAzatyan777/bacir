rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Invitations collection
    match /invitations/{invitationId} {
      allow read: if true; // Readable by everyone (guests)
      
      // Allow create if user is authenticated and sets themselves as the owner
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      
      // Allow update/delete only if the user is the owner of the document
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
      
      // Responses subcollection (RSVP replies from guests)
      match /responses/{responseId} {
        // Only the owner of the parent invitation can read the RSVP responses
        allow read: if request.auth != null && get(/databases/$(database)/documents/invitations/$(invitationId)).data.ownerId == request.auth.uid;
        allow write: if true; // Writable by everyone (guests submitting RSVPs)
      }
    }

    // Invitation Secrets (Telegram Bot Token & Chat ID)
    match /invitationSecrets/{invitationId} {
      // Only the owner of the parent invitation can read or write its secrets
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/invitations/$(invitationId)).data.ownerId == request.auth.uid;
    }
  }
}
