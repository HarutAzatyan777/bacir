rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /invitations/{slug}/{allPaths=**} {
      allow read: if true; // Publicly readable so guests can see the images
      
      // Allow write if authenticated, and either:
      // 1. The invitation document does not exist yet (creating a new invitation)
      // 2. The user is the owner of the existing invitation in Firestore
      allow write: if request.auth != null && (
        !firestore.exists(/databases/(default)/documents/invitations/$(slug)) ||
        firestore.get(/databases/(default)/documents/invitations/$(slug)).data.ownerId == request.auth.uid
      );
    }
  }
}