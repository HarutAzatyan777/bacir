{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/i/:id",
      "destination": "/api/seoHandler?id=:id"
    },
    {
      "source": "/i/:id/",
      "destination": "/api/seoHandler?id=:id"
    },
    {
      "source": "/((?!api|static|.*\\..*$).*)",
      "destination": "/index.html"
    }
  ]
}
